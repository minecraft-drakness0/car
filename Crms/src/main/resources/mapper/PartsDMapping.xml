<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.subati.crms.dao.PartsDDao">
    <select id="getAllPartsD" resultType="com.subati.crms.bean.PartsD">
        SELECT * FROM partsdelivery
        <if test="part_number !=null ">
            WHERE part_number like #{part_number}
        </if>
        LIMIT #{pageStart},#{pageSize}
    </select>

    <select id="getPartsDCounts" resultType="java.lang.Integer">
        SELECT count(*) FROM partsdelivery
        <if test="part_number !=null ">
            WHERE part_number like #{part_number}
        </if>
    </select>

    <insert id="addPartsD">
        INSERT INTO partsdelivery
        (part_number,delivery_quantity,inventory_quantity,price)
        VALUE(#{part_number},#{delivery_quantity},#{inventory_quantity},#{price})
    </insert>

    <delete id="deletePartsD">
        DELETE FROM partsdelivery WHERE id = #{id}
    </delete>

    <select id="getUpdatePartsD" resultType="com.subati.crms.bean.PartsD">
        SELECT * FROM partsdelivery WHERE id = #{id}
    </select>
    <select id="getAll" resultType="com.subati.crms.bean.PartsD">
        select * from partsdelivery
    </select>

    <update id="editPartsD">
        UPDATE partsdelivery SET part_number = #{part_number} , delivery_quantity = #{delivery_quantity} ,
        inventory_quantity = #{inventory_quantity} , price = #{price} WHERE id = #{id}
    </update>
</mapper>